{
  "name": "davishacks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"next,expo\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"npm:dev:web\" \"npm:dev:mobile\"",
    "dev:web": "next dev -H 0.0.0.0",
    "dev:mobile": "cd mobile && npx expo start",
    "build": "npm run farm:publish && next build",
    "start": "next start",
    "lint": "eslint",
    "farm:build": "tsc -p farmManager/tsconfig.json",
    "farm:publish": "npm run farm:build && rm -rf public/farm-manager && mkdir -p public/farm-manager && cp -R farmManager/dist public/farm-manager/dist",
    "db:seed": "node scripts/seed.mjs",
    "db:seed:marketplace": "node scripts/seed-marketplace.mjs",
    "db:consolidate": "node scripts/consolidate-mongo.mjs",
    "db:seed:plants": "node scripts/seed-plants.mjs"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.24.0",
    "mongodb": "^7.2.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "concurrently": "^9.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
