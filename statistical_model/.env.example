# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=farm_optim

# Logging
LOG_LEVEL=INFO

# Public-data API keys — all OPTIONAL for the MVP.
# The system runs end-to-end on seed data alone; ingestion modules degrade
# gracefully when keys are missing.
NASS_API_KEY=
AMS_API_KEY=
NOAA_TOKEN=
OPENET_API_KEY=

# Default farm context (used by run_sample.py)
DEFAULT_FARM_ID=farm_001
DEFAULT_SEASON_YEAR=2026
